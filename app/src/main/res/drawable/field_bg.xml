<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#F7F8FA" />

    <!-- Border -->
    <stroke
        android:width="1.5dp"
        android:color="#E2E8F0" />

    <!-- Rounded corners -->
    <corners android:radius="10dp" />

    <!-- Optional padding -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="10dp"
        android:bottom="10dp" />

</shape>